msgid "WP_DEBUG is enabled. This reveals PHP errors and notices on every page, which may expose sensitive information to visitors. Disable it in wp-config.php by setting `define( 'WP_DEBUG', false );` before going live."
msgstr ""

#: includes/class-health-checks.php
msgid "WP_DEBUG_LOG is active. PHP errors are being written to a log file (usually wp-content/debug.log). This file is publicly accessible by default. Either protect it with server rules or set `define( 'WP_DEBUG_LOG', false );` to stop logging."
msgstr ""

#. translators: %s is the minimum recommended PHP version string, e.g. "8.0"
#: includes/class-health-checks.php
